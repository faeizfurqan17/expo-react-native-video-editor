index 5297d22..aa16544 100644
--- a/node_modules/@azzapp/react-native-skia-video/ios/MTLTextureUtils.mm
+++ b/node_modules/@azzapp/react-native-skia-video/ios/MTLTextureUtils.mm
@@ -7,6 +7,7 @@
 
 #import "MTLTextureUtils.h"
 #import <Metal/Metal.h>
+#import <QuartzCore/QuartzCore.h>
 #import <stdexcept>
 
 @implementation MTLTextureUtils
@@ -106,4 +107,75 @@ + (void)updateTexture:(id<MTLTexture>)mtlTexture
   CVPixelBufferUnlockBaseAddress(pixelBuffer, kCVPixelBufferLock_ReadOnly);
 }
 
++ (void)updateTextureAsync:(id<MTLTexture>)mtlTexture
+                       with:(CVPixelBufferRef)pixelBuffer
+                 completion:(void (^)(void))completion {
+  CVPixelBufferLockBaseAddress(pixelBuffer, kCVPixelBufferLock_ReadOnly);
+
+  size_t width = CVPixelBufferGetWidth(pixelBuffer);
+  size_t height = CVPixelBufferGetHeight(pixelBuffer);
+
+  if (width > mtlTexture.width || height > mtlTexture.height) {
+    CVPixelBufferUnlockBaseAddress(pixelBuffer, kCVPixelBufferLock_ReadOnly);
+    throw std::runtime_error(
+        "Pixel buffer dimensions exceed texture dimensions!");
+  }
+
+  CVMetalTextureRef cvMetalTexture = NULL;
+  CVReturn status = CVMetalTextureCacheCreateTextureFromImage(
+      NULL, getMetalTextureCache(), pixelBuffer, NULL, MTLPixelFormatBGRA8Unorm,
+      width, height, 0, &cvMetalTexture);
+
+  if (status != kCVReturnSuccess || !cvMetalTexture) {
+    CVPixelBufferUnlockBaseAddress(pixelBuffer, kCVPixelBufferLock_ReadOnly);
+    throw std::runtime_error(
+        "Failed to create Metal texture from CVPixelBuffer!");
+  }
+
+  id<MTLTexture> tempTexture = CVMetalTextureGetTexture(cvMetalTexture);
+
+  auto commandQueue = getCommandQueue();
+  id<MTLCommandBuffer> commandBuffer = [commandQueue commandBuffer];
+  id<MTLBlitCommandEncoder> blitEncoder = [commandBuffer blitCommandEncoder];
+
+  MTLRegion region = MTLRegionMake2D(0, 0, width, height);
+
+  [blitEncoder copyFromTexture:tempTexture
+                   sourceSlice:0
+                   sourceLevel:0
+                  sourceOrigin:region.origin
+                    sourceSize:region.size
+                     toTexture:mtlTexture
+              destinationSlice:0
+              destinationLevel:0
+             destinationOrigin:region.origin];
+
+  [blitEncoder endEncoding];
+
+  // NOTE: no waitUntilCompleted here — that was a per-frame main-thread
+  // stall proportional to buffer size, which compounds under load (heavy
+  // source -> slower blit -> more time blocked -> fewer decodeNextFrame
+  // calls actually get through -> looks "stuck" to callers even though the
+  // decoder is still making progress). The completion handler fires on an
+  // internal Metal dispatch queue once the copy has actually landed; the
+  // pixel buffer and temp CV texture must stay alive until then, so they're
+  // released inside the handler rather than immediately after commit.
+  CFTimeInterval commitTime = CACurrentMediaTime();
+  [commandBuffer addCompletedHandler:^(id<MTLCommandBuffer> _Nonnull) {
+    // [diag] commit->completed latency; log only when the GPU copy itself is
+    // slow enough to matter (it shouldn't be — this identifies GPU contention
+    // if it is).
+    CFTimeInterval blitMs = (CACurrentMediaTime() - commitTime) * 1000.0;
+    if (blitMs > 8.0) {
+      NSLog(@"[skia-video][diag] blit commit->completed took %.1fms", blitMs);
+    }
+    CFRelease(cvMetalTexture);
+    CVPixelBufferUnlockBaseAddress(pixelBuffer, kCVPixelBufferLock_ReadOnly);
+    if (completion) {
+      completion();
+    }
+  }];
+  [commandBuffer commit];
+}
+
 @end
