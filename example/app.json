{
  "expo": {
    "name": "Video Editor Example",
    "slug": "video-editor-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "video-editor-example",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.faeizfurqan.videoeditor",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to record video",
        "NSMicrophoneUsageDescription": "This app needs microphone access to record audio",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to select videos"
      },
      "appleTeamId": "693F7ZVF34"
    },
    "android": {
      "package": "com.faeizfurqan.videoeditor",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-audio",
      "expo-image-picker",
      [
        "./plugins/with-ffmpeg-kit",
        {
          "package": "full"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ]
  }
}
