{
  "name": "@anthropic/react-native-video-editor",
  "version": "0.1.0",
  "description": "Open-source React Native video editor with trim, crop, filters, effects, text, stickers, and audio",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
